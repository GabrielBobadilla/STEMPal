# ====================
# STEMPal Environment Variables
# ====================

# App
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=stempal
# Set DB_SSL=true for cloud databases (PlanetScale, Aiven, etc.)
DB_SSL=false

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Gemini AI (used for all AI features)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
